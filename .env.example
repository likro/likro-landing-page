# Likro Landing Page — variáveis de ambiente
#
# Copiar para .env.local e preencher com valores reais.
# .env.local NUNCA é commitado. Apenas este arquivo (.env.example) versionado.
#
# Convenção:
# - NEXT_PUBLIC_*: exposto ao bundle client (IDs públicos de analytics, número WhatsApp).
# - Sem prefixo: server-only secrets (lidos apenas em route handlers, server actions).

# --- Público (client + server) ---
# Número WhatsApp do Lenny (formato: 55 + DDD + número, sem espaços/+/hífens).
# Validado por src/lib/whatsapp.ts (12-13 dígitos puros).
NEXT_PUBLIC_WA_NUMBER=5511999999999

# IDs de analytics. Vazio = no-op (track helper é silencioso).
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# --- Server-only secrets (Phase 5 — Lead form) ---
# NÃO prefixar com NEXT_PUBLIC_ — lidos apenas em route handlers / server actions.
# Nunca expostos ao bundle client.
#
# A v1 entrega o lead via Resend (email) + Google Sheets (planilha de backup).
# NOTA: o REQUIREMENTS.md menciona `LEAD_WEBHOOK_URL` — esse nome é MORTO:
# a v1 não usa webhook genérico; usa Resend + Google Sheets. NÃO criar essa var.
RESEND_API_KEY=re_xxxxxxxxxxxx
LEAD_TO_EMAIL=lenny@likro.com.br
GOOGLE_SA_CLIENT_EMAIL=likro-leads@your-project.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789AbCdE

# --- Deploy (Vercel) ---
# DEPLOY-03: configurar TODAS as vars acima em Vercel → Settings → Environment
#   Variables, nos 3 escopos (Production, Preview, Development).
#   As 3 IDs de analytics (GA4 / Meta Pixel / Clarity) vazias = no-op silencioso;
#   preencher antes de rodar tráfego pago. Configuração na Vercel é HUMAN-UAT (07-06).
# DEPLOY-04: site já no ar em URL .vercel.app — domínio próprio é DNS posterior.
# VERCEL_ENV / VERCEL_URL são injetadas automaticamente pela Vercel — não declarar aqui.
